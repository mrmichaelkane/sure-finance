<div class="space-y-6">
  <%= render "advanced_reports/shared/sub_nav" %>

  <div class="rounded-xl border border-primary bg-container p-6">
    <h1 class="text-xl font-medium text-primary"><%= t(".title") %></h1>
  </div>

  <div class="rounded-xl border border-primary bg-container p-4 md:p-6">
    <%= form_with url: advanced_reports_monthly_trends_path,
                  method: :get,
                  data: { controller: "auto-submit-form", turbo_frame: "monthly_trends_report" },
                  class: "grid gap-4 xl:grid-cols-5" do |form| %>
      <div class="space-y-1">
        <%= form.label :preset, t(".filters.date_range"), class: "text-sm font-medium text-secondary" %>
        <%= form.select :preset,
                        options_for_select([
                          [t(".presets.last_12_months"), "last_12_months"],
                          [t(".presets.last_24_months"), "last_24_months"],
                          [t(".presets.ytd"), "ytd"],
                          [t(".presets.custom"), "custom"]
                        ], @preset),
                        {},
                        data: { auto_submit_form_target: "auto" },
                        class: "w-full rounded-lg border border-primary bg-surface px-3 py-2 text-sm text-primary" %>
      </div>

      <div class="space-y-1">
        <%= form.label :mode, t(".filters.show"), class: "text-sm font-medium text-secondary" %>
        <%= form.select :mode,
                        options_for_select([
                          [t(".modes.expenses"), "expenses"],
                          [t(".modes.income"), "income"],
                          [t(".modes.both"), "both"]
                        ], @mode),
                        {},
                        data: { auto_submit_form_target: "auto" },
                        class: "w-full rounded-lg border border-primary bg-surface px-3 py-2 text-sm text-primary" %>
      </div>

      <div class="space-y-1">
        <%= form.label :account_id, t(".filters.account"), class: "text-sm font-medium text-secondary" %>
        <%= form.select :account_id,
                        options_for_select([[t(".filters.all_accounts"), nil]] + @accounts.map { |account| [account.name, account.id] }, @selected_account_id),
                        {},
                        data: { auto_submit_form_target: "auto" },
                        class: "w-full rounded-lg border border-primary bg-surface px-3 py-2 text-sm text-primary" %>
      </div>

      <div class="space-y-1">
        <%= form.label :category_id, t(".filters.category"), class: "text-sm font-medium text-secondary" %>
        <%= form.select :category_id,
                        options_for_select([[t(".filters.all_categories"), nil]] + @categories.map { |category| [category.name_with_parent, category.id] }, @selected_category_id),
                        {},
                        data: { auto_submit_form_target: "auto" },
                        class: "w-full rounded-lg border border-primary bg-surface px-3 py-2 text-sm text-primary" %>
      </div>

      <div class="grid grid-cols-2 gap-4 xl:grid-cols-1 xl:gap-1">
        <div class="space-y-1">
          <%= form.label :start_date, t(".filters.start_date"), class: "text-sm font-medium text-secondary" %>
          <%= form.date_field :start_date,
                              value: @date_range_filter.start_date&.strftime("%Y-%m-%d"),
                              data: { auto_submit_form_target: "auto" },
                              class: "w-full rounded-lg border border-primary bg-surface px-3 py-2 text-sm text-primary" %>
        </div>

        <div class="space-y-1">
          <%= form.label :end_date, t(".filters.end_date"), class: "text-sm font-medium text-secondary" %>
          <%= form.date_field :end_date,
                              value: @date_range_filter.end_date&.strftime("%Y-%m-%d"),
                              data: { auto_submit_form_target: "auto" },
                              class: "w-full rounded-lg border border-primary bg-surface px-3 py-2 text-sm text-primary" %>
        </div>
      </div>
    <% end %>
  </div>

  <%= turbo_frame_tag "monthly_trends_report" do %>
    <%= render "report", report: @report %>
  <% end %>
</div>

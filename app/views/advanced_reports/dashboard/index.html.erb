<div class="space-y-6">
  <%= render "advanced_reports/shared/sub_nav" %>

  <div class="rounded-xl border border-primary bg-container p-6">
    <h1 class="text-xl font-medium text-primary"><%= t(".title") %></h1>
    <p class="mt-2 text-secondary text-sm"><%= t(".description") %></p>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <%= link_to advanced_reports_income_expenses_path,
                class: "rounded-xl border border-primary bg-container p-6 transition-colors hover:bg-surface-hover" do %>
      <div class="flex items-start justify-between gap-4">
        <div class="space-y-2">
          <h2 class="text-lg font-medium text-primary">
            <%= t(".income_expenses.title") %>
          </h2>
          <p class="text-sm text-secondary">
            <%= t(".income_expenses.description") %>
          </p>
        </div>

        <%= icon("arrow-right", size: "sm") %>
      </div>
    <% end %>

    <%= link_to advanced_reports_monthly_trends_path,
                class: "rounded-xl border border-primary bg-container p-6 transition-colors hover:bg-surface-hover" do %>
      <div class="flex items-start justify-between gap-4">
        <div class="space-y-2">
          <h2 class="text-lg font-medium text-primary">
            <%= t(".monthly_trends.title") %>
          </h2>
          <p class="text-sm text-secondary">
            <%= t(".monthly_trends.description") %>
          </p>
        </div>

        <%= icon("arrow-right", size: "sm") %>
      </div>
    <% end %>

    <%= link_to advanced_reports_tag_analysis_index_path,
                class: "rounded-xl border border-primary bg-container p-6 transition-colors hover:bg-surface-hover" do %>
      <div class="flex items-start justify-between gap-4">
        <div class="space-y-2">
          <h2 class="text-lg font-medium text-primary">
            <%= t(".tag_analysis.title") %>
          </h2>
          <p class="text-sm text-secondary">
            <%= t(".tag_analysis.description") %>
          </p>
        </div>

        <%= icon("arrow-right", size: "sm") %>
      </div>
    <% end %>
  </div>
</div>
